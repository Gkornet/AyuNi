# Aylani — omgevingsvariabelen
# Kopieer dit bestand naar .env.local en vul je sleutels in.
# .env.local wordt NOOIT gecommit (staat in .gitignore).

# ─── Anthropic (intake-conversatie) ──────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Clerk (authenticatie) ───────────────────────────────────────
# Haal op via: https://dashboard.clerk.com → jouw app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk webhook signing secret (voor profiel-sync)
# Stel in via: Clerk Dashboard → Webhooks → jouw endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Supabase (database) ─────────────────────────────────────────
# Haal op via: https://supabase.com → jouw project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
